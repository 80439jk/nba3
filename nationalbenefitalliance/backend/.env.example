# ============================================================
# National Benefit Alliance — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
NODE_ENV=production
PORT=3000

# Domain (used for CORS, email links)
SITE_URL=https://nationalbenefitalliance.com
APPLY_URL=https://apply.nationalbenefitalliance.com
ALLOWED_ORIGINS=https://nationalbenefitalliance.com,https://apply.nationalbenefitalliance.com

# ============================================================
# PostgreSQL Database
# ============================================================
DATABASE_URL=postgresql://nba_user:your_password@localhost:5432/nba_db

# OR individual vars (used if DATABASE_URL is not set):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nba_db
DB_USER=nba_user
DB_PASSWORD=your_secure_password_here
DB_SSL=true

# ============================================================
# Email (SMTP / SendGrid)
# Recommended: SendGrid — https://sendgrid.com
# ============================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
EMAIL_FROM=noreply@nationalbenefitalliance.com
EMAIL_FROM_NAME=National Benefit Alliance

# ============================================================
# Security
# ============================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_64_char_hex_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Rate limiting (requests per window)
RATE_LIMIT_API=100
RATE_LIMIT_CODE=10

# ============================================================
# PDF Generation (Puppeteer)
# ============================================================
# Path to Chrome/Chromium for Puppeteer
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PDF_STORAGE_PATH=./public/downloads/

# ============================================================
# Analytics (optional)
# ============================================================
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GTM_CONTAINER_ID=GTM-XXXXXXX

# ============================================================
# Deployment
# ============================================================
# Subdomain routing — configure in Nginx/Caddy
# apply.nationalbenefitalliance.com → same server, /apply/ route
